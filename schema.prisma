datasource db {
  provider = "postgresql"
  // Wasp requires that the url is set to the DATABASE_URL environment variable.
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  DONE @map("done")
  PROG @map("in_progress")
  TODO @map("todo")
}

// Wasp requires the `prisma-client-js` generator to be present.
generator client {
  provider = "prisma-client-js"
}

// Developer entity model
model Developer {
  id String @id @default(uuid())
  createdAt DateTime @default(now())
  name String @unique
  skills Skill[] //  a developer may have many skills
  tasks Task[]
}

model Task {
  id String @id @default(uuid())
  title String @unique
  createdAt DateTime @default(now())
  developer Developer @relation(references: [id], fields: [developerId])
  developerId String
  status TaskStatus @default(TODO)
  skills Skill[] // a task may have many skills
}

model Skill {
  id String @id @default(uuid())
  name String @unique
  createdAt DateTime @default(now())
  tasks Task[]
  developers Developer[]
}
